{
    "name": "daniel-km/omeka-s-module-extract-ocr",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Extract text layer from a pdf and attach it to item as a xml file, formatted with standard \"alto\" or simple \"pdf2xml\" or common \"tsv\". The process uses the command line tool pdftohtml of poppler.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "ocr",
        "pdf",
        "alto",
        "tsv"
    ],
    "license": "GPL-3.0-or-later",
    "homepage": "http://github.com/bubdxm/Omeka-S-module-ExtractOcr",
    "authors": [
        {
            "name": "Xavier Muller",
            "email": "xavier.muller@etu.u-bordeaux.fr"
        },
        {
            "name": "Symac",
            "email": "web@geobib.fr"
        },
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "http://github.com/bubdxm/Omeka-S-module-ExtractOcr/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ExtractOcr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ExtractOcrTest\\": "tests/ExtractOcrTest/"
        }
    },
    "extra": {
        "installer-name": "ExtractOcr",
        "configurable": true
    }
}
